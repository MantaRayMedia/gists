+  /**
+   * Helper for creating an icon element.
+   *
+   * @param writer
+   * @param iconFA
+   * @param iconStyle
+   * @private
+   */
+  private _createIconElement(writer: any, iconFA: any, iconStyle: string): any {
+    let linkHref: string | undefined;
+    const linkElement = this._getSelectedLinkElement();
+    if (linkElement)
+      linkHref = linkElement.getAttribute('href');
+
+    return writer.createElement('icon', linkHref ? {linkHref, iconFA, iconStyle} : {
+      iconFA,
+      iconStyle
+    });
+  }
+
+  /**
+   * Creates a wrapper element containing an icon and selected text content.
+   * The original selection in the editor is replaced by this wrapper element,
+   * which includes an icon followed by the textual or other content.
+   *
+   * @param {module:engine/model/writer~Writer} writer The writer instance used to handle the model changes.
+   * @param {module:engine/model/selection~Selection} selection The current selection in the editor model.
+   * @param {String} iconFA The FontAwesome icon class (e.g., 'fa-icon-name') used for the icon element.
+   * @param {Object} iconStyle An object defining the styling attributes to be applied to the icon.
+   * @return {void} This method does not return any value.
+   */
+  _createIconWithTextWrapper(writer, selection, iconFA, iconStyle) {
+    const model = this.editor.model;
+    const range = selection.getFirstRange();
+    const selectedContent = model.getSelectedContent(selection);
+
+    // Remove what was selected
+    writer.remove(range);
+
+    // Create paragraph
+    const container = writer.createElement('paragraph');
+    model.insertContent(container, selection.getFirstPosition());
+
+    // Insert icon
+    const iconElement = writer.createElement('icon', { iconFA, iconStyle });
+    writer.insert(iconElement, writer.createPositionAt(container, 0));
+
+    // Add text content
+    let textCount = 0;
+    for (const child of selectedContent.getChildren()) {
+      if (child.is('$text')) {
+        writer.insertText(child.data, child.getAttributes(), container, 'end');
+        textCount++;
+      } else if (child.is('element') && child.name !== 'icon') {
+        const el = writer.createElement(child.name, child.getAttributes());
+        writer.insert(el, writer.createPositionAt(container, 'end'));
+      }
+    }
+
+    writer.setSelection(container, 'end');
+  }
